{
  "manifest_version": 3,
  "name": "AI Web Augmenter",
  "version": "1.0.0",
  "description": "Transform webpages into an AI workspace with summaries, Q&A, matching, and career tools.",
  "permissions": ["activeTab", "scripting", "storage", "contextMenus", "notifications"],
  "host_permissions": ["http://localhost:4000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Web Augmenter"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}